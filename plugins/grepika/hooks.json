{
  "description": "Redirect code search to grepika MCP tools for token-efficient results",
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/grepika-hint.sh",
            "timeout": 5,
            "async": true
          }
        ]
      }
    ]
  }
}
